#!/usr/bin/env bash
#
# cassette-toggle — start/stop helper for the cassette PHP recording extension.
#
# Usage:
#   ./cassette-toggle start [--php=8.5] [--root=/var/www/my-project]
#   ./cassette-toggle stop  [--php=8.5] [--root=/var/www/my-project]
#
# What it does on `start`:
#   1. Writes /etc/php/<ver>/fpm/conf.d/zzz-cassette.ini (uopz, opcache, xdebug, blackfire)
#   2. Enables the uopz module (phpenmod -v <ver> uopz)
#   3. For PHP 8.5: builds & installs an LD_PRELOAD shim that provides the
#      `zend_exception_get_default` symbol removed in PHP 8.5 (uopz still references it)
#      and registers a systemd drop-in for php<ver>-fpm so the shim is loaded.
#   4. Restarts php<ver>-fpm
#   5. With --root: detects WordPress (wp-config.php) or Laravel (public/index.php)
#      and injects the cassette bootstrap line — wrapped in markers so the matching
#      `stop` invocation can remove it cleanly.
#
# `stop` reverses every step.
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly INI_BASENAME='zzz-cassette.ini'
readonly SHIM_SO='/usr/local/lib/uopz-php85-shim.so'
readonly MARKER_BEGIN='// >>> cassette-toggle (auto-managed) — do not edit'
readonly MARKER_END='// <<< cassette-toggle'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

color() { printf '\033[%sm%s\033[0m' "$1" "$2"; }
info()  { printf '%s %s\n' "$(color '1;34' '·')" "$*"; }
ok()    { printf '%s %s\n' "$(color '1;32' '✓')" "$*"; }
warn()  { printf '%s %s\n' "$(color '1;33' '!')" "$*" >&2; }
die()   { printf '%s %s\n' "$(color '1;31' '✗')" "$*" >&2; exit 1; }

usage() {
    cat >&2 <<EOF
Usage:
  $(basename "$0") start [--php=<version>] [--root=<path>]
  $(basename "$0") stop  [--php=<version>] [--root=<path>]

Options:
  --php=<version>   PHP version to toggle (e.g. 8.3, 8.5).
                    Default: contents of $SCRIPT_DIR/.phprc, otherwise 8.5.
  --root=<path>     Project root. When given, the cassette bootstrap line is
                    injected (start) or removed (stop) in the project's
                    wp-config.php (WordPress) or public/index.php (Laravel).
EOF
    exit 1
}

# Resolve the PHP version: CLI arg overrides .phprc, which overrides 8.5.
resolve_php_version() {
    local fromArg="$1"
    if [[ -n "$fromArg" ]]; then
        printf '%s' "$fromArg"
        return
    fi
    if [[ -f "$SCRIPT_DIR/.phprc" ]]; then
        local v
        v="$(tr -d '[:space:]' < "$SCRIPT_DIR/.phprc")"
        if [[ -n "$v" ]]; then
            printf '%s' "$v"
            return
        fi
    fi
    printf '8.5'
}

# Check that /etc/php/<ver>/fpm/conf.d exists, otherwise the version is not installed.
require_php_version_installed() {
    local ver="$1"
    [[ -d "/etc/php/$ver/fpm/conf.d" ]] \
        || die "PHP $ver is not installed (no /etc/php/$ver/fpm/conf.d directory)."
}

# ---------------------------------------------------------------------------
# uopz / php-fpm enable & disable
# ---------------------------------------------------------------------------

write_ini() {
    local ver="$1"
    local target="/etc/php/$ver/fpm/conf.d/$INI_BASENAME"
    info "Writing $target"
    sudo tee "$target" >/dev/null <<'EOF'
[uopz]
uopz.exit = 1
[opcache]
opcache.enable = 0
[xdebug]
xdebug.mode = off
[blackfire]
blackfire.apm_enabled = 0
EOF
}

remove_ini() {
    local ver="$1"
    local target="/etc/php/$ver/fpm/conf.d/$INI_BASENAME"
    if [[ -f "$target" ]]; then
        info "Removing $target"
        sudo rm -f "$target"
    fi
}

enable_uopz_module() {
    local ver="$1"
    info "phpenmod -v $ver uopz"
    sudo phpenmod -v "$ver" uopz
}

disable_uopz_module() {
    local ver="$1"
    info "phpdismod -v $ver uopz"
    sudo phpdismod -v "$ver" uopz || true
}

restart_fpm() {
    local ver="$1"
    local unit="php$ver-fpm.service"
    # `systemctl cat` exits non-zero (and prints to stderr) when the unit does
    # not exist. Suppressing stderr keeps the script output clean while still
    # giving a reliable presence check.
    if ! systemctl cat "$unit" >/dev/null 2>&1; then
        warn "Skipping restart: systemd unit $unit not found."
        return
    fi
    info "systemctl restart $unit"
    sudo systemctl restart "$unit"
}

# ---------------------------------------------------------------------------
# PHP 8.5 uopz patch (LD_PRELOAD shim)
# ---------------------------------------------------------------------------
#
# uopz still references `zend_exception_get_default()`, which was removed from
# PHP core in 8.5. Symptom: dlopen fails with
#   undefined symbol: zend_exception_get_default
#
# Fix without rebuilding uopz: provide the missing symbol via a tiny shared
# library that just returns the still-existing `zend_ce_exception` global, and
# load it with LD_PRELOAD so the dynamic linker resolves the reference at
# load time.
#
# The shim is harmless on other PHP versions because nothing references the
# symbol there — it just sits in memory unused.

needs_php85_shim() {
    [[ "$1" == 8.5* ]]
}

build_shim_if_missing() {
    if [[ -f "$SHIM_SO" ]]; then
        return
    fi
    info "Building uopz PHP 8.5 shim → $SHIM_SO"
    command -v gcc >/dev/null || die "gcc is required to build the PHP 8.5 uopz shim. apt install build-essential"
    local src
    src="$(mktemp --suffix=.c)"
    cat > "$src" <<'EOF'
/*
 * Shim providing zend_exception_get_default() — removed from PHP 8.5 core
 * but still referenced by uopz 7.1.x. Returns the unchanged zend_ce_exception
 * global so uopz behaves identically to PHP 8.4.
 */
extern void *zend_ce_exception;
void *zend_exception_get_default(void) { return zend_ce_exception; }
EOF
    sudo gcc -shared -fPIC -O2 -o "$SHIM_SO" "$src"
    rm -f "$src"
    ok "Built shim ($(stat -c%s "$SHIM_SO") bytes)"
}

install_shim_dropin() {
    local ver="$1"
    local unit="php$ver-fpm"
    local dir="/etc/systemd/system/$unit.service.d"
    local file="$dir/uopz-shim.conf"
    info "Installing systemd drop-in $file"
    sudo mkdir -p "$dir"
    sudo tee "$file" >/dev/null <<EOF
# Auto-managed by cassette-toggle. Loads the LD_PRELOAD shim that supplies
# the zend_exception_get_default symbol uopz still expects on PHP 8.5.
[Service]
Environment=LD_PRELOAD=$SHIM_SO
EOF
    sudo systemctl daemon-reload
}

remove_shim_dropin() {
    local ver="$1"
    local file="/etc/systemd/system/php$ver-fpm.service.d/uopz-shim.conf"
    if [[ -f "$file" ]]; then
        info "Removing systemd drop-in $file"
        sudo rm -f "$file"
        # Remove the now-empty drop-in dir so we don't leave clutter.
        sudo rmdir --ignore-fail-on-non-empty "$(dirname "$file")" 2>/dev/null || true
        sudo systemctl daemon-reload
    fi
}

# ---------------------------------------------------------------------------
# Bootstrap line injection
# ---------------------------------------------------------------------------

# Detect framework: prints "wordpress|<wp-config.php>" or "laravel|<index.php>".
detect_framework() {
    local root="$1"
    if [[ -f "$root/wp-config.php" ]]; then
        printf 'wordpress|%s/wp-config.php' "$root"
        return
    fi
    if [[ -f "$root/public/index.php" ]]; then
        printf 'laravel|%s/public/index.php' "$root"
        return
    fi
    die "Could not detect framework in $root (no wp-config.php and no public/index.php)."
}

# Build the bootstrap snippet. WordPress uses __DIR__/vendor (root file),
# Laravel uses __DIR__/../vendor (public/index.php sits one level below root).
build_snippet() {
    local kind="$1"
    local relativeVendor
    if [[ "$kind" == 'wordpress' ]]; then
        relativeVendor="__DIR__.'/vendor/vielhuber/cassette/src/bootstrap.php'"
    else
        relativeVendor="__DIR__.'/../vendor/vielhuber/cassette/src/bootstrap.php'"
    fi
    cat <<EOF
$MARKER_BEGIN
require_once file_exists('/var/www/cassette/src/bootstrap.php')
    ? '/var/www/cassette/src/bootstrap.php'
    : $relativeVendor;
$MARKER_END
EOF
}

snippet_already_present() {
    grep -qF "$MARKER_BEGIN" "$1"
}

inject_bootstrap_line() {
    local root="$1"
    local pair kind file
    pair="$(detect_framework "$root")"
    kind="${pair%%|*}"
    file="${pair#*|}"

    info "Detected $kind project, target file: $file"

    if snippet_already_present "$file"; then
        ok "Bootstrap snippet already present in $file — skipping."
        return
    fi

    local snippet
    snippet="$(build_snippet "$kind")"

    local tmp
    tmp="$(mktemp)"

    if [[ "$kind" == 'wordpress' ]]; then
        # Insert directly before `require_once ABSPATH . 'wp-settings.php';`.
        if ! grep -q "ABSPATH . 'wp-settings.php'" "$file"; then
            rm -f "$tmp"
            die "Could not find 'wp-settings.php' require in $file."
        fi
        awk -v snippet="$snippet" '
            !inserted && /ABSPATH \. .wp-settings\.php./ {
                print snippet
                print ""
                inserted = 1
            }
            { print }
        ' "$file" > "$tmp"
    else
        # Laravel: insert right after the opening <?php tag.
        awk -v snippet="$snippet" '
            !inserted && /^<\?php/ {
                print
                print ""
                print snippet
                inserted = 1
                next
            }
            { print }
        ' "$file" > "$tmp"
    fi

    sudo cp "$tmp" "$file"
    rm -f "$tmp"
    ok "Injected bootstrap snippet into $file"
}

remove_bootstrap_line() {
    local root="$1"
    local pair file
    pair="$(detect_framework "$root")"
    file="${pair#*|}"

    if [[ ! -f "$file" ]]; then
        warn "Target file $file not found — nothing to remove."
        return
    fi

    if ! snippet_already_present "$file"; then
        ok "No cassette-toggle snippet in $file — nothing to remove."
        return
    fi

    info "Removing snippet from $file"
    local tmp
    tmp="$(mktemp)"
    awk -v b="$MARKER_BEGIN" -v e="$MARKER_END" '
        index($0, b) { skipping = 1 }
        !skipping { print }
        index($0, e) { skipping = 0; next }
    ' "$file" > "$tmp"

    # Cap any blank-line cluster the snippet left behind at a single blank line.
    awk 'NF==0 { pending=1; next } { if (pending) { print ""; pending=0 } print }' "$tmp" > "$tmp.2"
    mv "$tmp.2" "$tmp"

    sudo cp "$tmp" "$file"
    rm -f "$tmp"
    ok "Removed cassette-toggle snippet from $file"
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_start() {
    local ver="$1" root="$2"
    require_php_version_installed "$ver"

    write_ini "$ver"
    enable_uopz_module "$ver"

    if needs_php85_shim "$ver"; then
        build_shim_if_missing
        install_shim_dropin "$ver"
    fi

    restart_fpm "$ver"

    if [[ -n "$root" ]]; then
        inject_bootstrap_line "$root"
    fi

    ok "cassette enabled for PHP $ver."
}

cmd_stop() {
    local ver="$1" root="$2"
    require_php_version_installed "$ver"

    # Remove the project-level injection first so a half-stopped state
    # never leaves the bootstrap line referencing a disabled extension.
    if [[ -n "$root" ]]; then
        remove_bootstrap_line "$root"
    fi

    if needs_php85_shim "$ver"; then
        remove_shim_dropin "$ver"
    fi

    remove_ini "$ver"
    disable_uopz_module "$ver"
    restart_fpm "$ver"

    ok "cassette disabled for PHP $ver."
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

main() {
    local subcommand="${1:-}"
    [[ "$subcommand" == 'start' || "$subcommand" == 'stop' ]] || usage
    shift

    local phpArg='' rootArg=''
    for arg in "$@"; do
        case "$arg" in
            --php=*)  phpArg="${arg#--php=}" ;;
            --root=*) rootArg="${arg#--root=}" ;;
            -h|--help) usage ;;
            *) die "Unknown argument: $arg" ;;
        esac
    done

    local ver
    ver="$(resolve_php_version "$phpArg")"

    if [[ -n "$rootArg" ]]; then
        rootArg="${rootArg%/}"
        [[ -d "$rootArg" ]] || die "--root path does not exist: $rootArg"
    fi

    info "PHP version: $ver"
    if [[ -n "$rootArg" ]]; then
        info "Project root: $rootArg"
    fi

    case "$subcommand" in
        start) cmd_start "$ver" "$rootArg" ;;
        stop)  cmd_stop  "$ver" "$rootArg" ;;
    esac
}

main "$@"
