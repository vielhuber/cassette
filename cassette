#!/usr/bin/env php
<?php
declare(strict_types=1);

/**
 * Cassette CLI helper.
 *
 * Usage:
 *   vendor/bin/cassette up         [--php=8.5] [--root=/path]  — enable uopz + inject bootstrap line
 *   vendor/bin/cassette down       [--php=8.5] [--root=/path]  — disable uopz + remove bootstrap line
 *   vendor/bin/cassette record     <name>     [--root=/path]   — switch to record mode and clear old cassette
 *   vendor/bin/cassette replay     <name>     [--root=/path]   — switch to mock mode and run the replay suite
 *   vendor/bin/cassette accept     <name>     [--root=/path]   — interactively accept HTTP diffs as new baseline
 *   vendor/bin/cassette stop       <name>     [--root=/path]   — stop recording, keep data for later replay
 *   vendor/bin/cassette delete     <name>     [--root=/path]   — delete a run and all its data
 *   vendor/bin/cassette list                  [--root=/path]   — list all recorded runs
 *
 * Project root resolution (in priority order):
 *   1. --root=<path>
 *   2. CASSETTE_ROOT environment variable
 *   3. Current working directory
 */

// Allow exit()/die() to actually terminate the process even when the uopz extension
// is loaded (it disables exit by default to support testing code that calls exit).
if (function_exists('uopz_allow_exit')) {
    uopz_allow_exit(true);
}

$command = $argv[1] ?? '';
$name    = $argv[2] ?? '';

// Parse --root=<path> and --php=<version> from any position in argv.
$projectRootOverride = null;
$phpVersionOverride  = null;
foreach ($argv as $__arg) {
    if (str_starts_with($__arg, '--root=')) {
        $projectRootOverride = rtrim(substr($__arg, 7), '/');
    } elseif (str_starts_with($__arg, '--php=')) {
        $phpVersionOverride = substr($__arg, 6);
    }
}
unset($__arg);

$nameRequired = in_array($command, ['record', 'replay', 'accept', 'stop', 'delete'], true);

if ($command === '' || ($nameRequired && $name === '')) {
    echo "Usage:\n";
    echo "  vendor/bin/cassette up      [--php=<ver>]               — enable uopz + inject bootstrap line\n";
    echo "  vendor/bin/cassette down    [--php=<ver>]               — disable uopz + remove bootstrap line\n";
    echo "  vendor/bin/cassette record  <name>                      — record a new flow\n";
    echo "  vendor/bin/cassette replay  <name> [options]            — HTTP diff + visual screenshot regression\n";
    echo "                                options: --refresh, --debug, --http-only,\n";
    echo "                                         --screenshot-only, --base-url=<url>\n";
    echo "  vendor/bin/cassette accept  <name>                      — interactively accept HTTP diffs as new baseline\n";
    echo "  vendor/bin/cassette stop    <name>                      — stop recording, keep data for later replay\n";
    echo "  vendor/bin/cassette delete  <name> [--force]            — delete a run and all its data\n";
    echo "  vendor/bin/cassette delete  --all [--force]             — delete all runs\n";
    echo "  vendor/bin/cassette list                                — list all recorded runs\n";
    echo "\n";
    echo "Project root resolution (priority order):\n";
    echo "  --root=<path>                                           — explicit override\n";
    echo "  CASSETTE_ROOT environment variable\n";
    echo "  Current working directory (default)\n";
    exit(1);
}

// Resolve project root: --root > CASSETTE_ROOT env > getcwd().
$envRoot     = (string) (getenv('CASSETTE_ROOT') ?: '');
$projectRoot = $projectRootOverride
    ?? ($envRoot !== '' ? rtrim($envRoot, '/') : (string) getcwd());

if (!is_dir($projectRoot)) {
    fwrite(STDERR, "Error: project root does not exist: $projectRoot\n");
    fwrite(STDERR, "Pass --root=<path>, set CASSETTE_ROOT, or run from inside the project.\n");
    exit(1);
}

$configPath   = $projectRoot . '/.cassette/state.json';
$cassettesDir = $projectRoot . '/.cassette/runs';

// Ensure the data directory exists before reading state.
if (!is_dir($cassettesDir)) {
    // recursive: true also creates the .cassette parent if it does not yet exist.
    mkdir($cassettesDir, 0775, true);
}

// Drop a .gitignore inside .cassette/ that excludes everything so the whole
// directory stays out of the project's git history without touching the
// project's own .gitignore file. Self-contained: nothing leaks into the user's
// repo configuration.
$cassetteRoot       = dirname($cassettesDir);
$cassetteGitignore  = $cassetteRoot . '/.gitignore';
if (!file_exists($cassetteGitignore)) {
    file_put_contents($cassetteGitignore, "*\n");
}

// Auto-create .cassette/config.json from the bundled example if not yet present.
$projectConfigPath = $cassetteRoot . '/config.json';
if (!file_exists($projectConfigPath)) {
    $examplePath = __DIR__ . '/config.example.json';
    if (file_exists($examplePath)) {
        copy($examplePath, $projectConfigPath);
    }
}

$config = file_exists($configPath)
    ? (json_decode((string) file_get_contents($configPath), true) ?? [])
    : [];

switch ($command) {
    case 'up':
    case 'down':
        require_once __DIR__ . '/src/CassetteToggle.php';
        $phpVersion = CassetteToggle::resolvePhpVersion($phpVersionOverride, __DIR__);
        if ($command === 'up') {
            CassetteToggle::up($phpVersion, $projectRoot);
        } else {
            CassetteToggle::down($phpVersion, $projectRoot);
        }
        break;

    case 'record':
        // Delete existing cassette files so a clean recording starts.
        // data.counter must also be removed — otherwise the previous run's
        // counter value carries over and the fresh recording starts at a
        // non-zero bucket index, leaving gaps at 0..N-1.
        $toDelete = [
            $cassettesDir . '/' . $name . '/data.json',
            $cassettesDir . '/' . $name . '/data.pointer',
            $cassettesDir . '/' . $name . '/data.counter',
            $cassettesDir . '/' . $name . '/http.json',
            $cassettesDir . '/' . $name . '/.started',
        ];

        foreach ($toDelete as $path) {
            if (file_exists($path)) {
                unlink($path);
            }
        }

        // buckets/ holds the per-bucket files that replaced the monolithic
        // data.json — nuke it so the fresh recording does not mix old buckets
        // into the new flow.
        $bucketsDir = $cassettesDir . '/' . $name . '/buckets';
        if (is_dir($bucketsDir)) {
            foreach (glob($bucketsDir . '/*.json.gz') ?: [] as $old) {
                unlink($old);
            }
        }

        // screenshots/ holds Playwright baselines tied to the previous flow.
        // A fresh recording almost always renders different content (different
        // pages visited, different cookie state, different URLs) so the old
        // baselines would mismatch the new replay and fail with confusing
        // "screenshot did not stabilize" timeouts (toHaveScreenshot retries
        // until it gives up). Wipe them so the next replay creates new ones.
        $screenshotsDir = $cassettesDir . '/' . $name . '/screenshots';
        if (is_dir($screenshotsDir)) {
            foreach (glob($screenshotsDir . '/*.png') ?: [] as $old) {
                unlink($old);
            }
        }

        // http/ holds .diff and .actual files from previous failed replays —
        // stale once the recording changes. Wipe them too.
        $httpDir = $cassettesDir . '/' . $name . '/http';
        if (is_dir($httpDir)) {
            foreach (glob($httpDir . '/*') ?: [] as $old) {
                if (is_file($old)) {
                    unlink($old);
                }
            }
        }

        $config['mode'] = 'record';
        $config['name'] = $name;

        file_put_contents($configPath, json_encode($config, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");

        echo "\033[33m● Recording started\033[0m  cassette: \033[1m$name\033[0m\n";
        echo "\n  \033[1mOpen your browser at\033[0m \033[36m/\033[0m and start recording.\n";
        echo "\n  Press \033[1mc\033[0m to stop recording.\n";

        // Switch terminal to single-char (cbreak) mode so 'c' is read without Enter.
        // Register a shutdown function to restore the terminal even on Ctrl+C / SIGINT.
        register_shutdown_function(static function (): void {
            exec('stty sane 2>/dev/null');
        });
        exec('stty cbreak -echo 2>/dev/null');
        while (true) {
            $char = fread(STDIN, 1);
            if ($char === 'c' || $char === 'C') {
                break;
            }
        }
        exec('stty sane 2>/dev/null');
        echo "\n";

        // Auto-stop: deactivate recording.
        clearState($configPath);
        echo "\033[32m✅ Recording stopped\033[0m  cassette: \033[1m$name\033[0m\n";
        echo "\n  Run when ready:\n";
        echo "  \033[36mvendor/bin/cassette replay $name\033[0m\n";
        break;

    case 'stop':
        if (($config['mode'] ?? '') !== 'record' || ($config['name'] ?? '') !== $name) {
            fwrite(STDERR, "Run '$name' is not currently recording.\n");
            exit(1);
        }

        // Deactivate recording — state.json is deleted so bootstrap.php becomes a no-op.
        clearState($configPath);

        echo "\033[32m✅ Recording stopped\033[0m  cassette: \033[1m$name\033[0m\n";
        echo "\n  Run when ready:\n";
        echo "  \033[36mvendor/bin/cassette replay $name\033[0m\n";
        break;

    case 'replay':
        if (!file_exists($cassettesDir . '/' . $name . '/http.json')) {
            fwrite(STDERR, "Run not found: $name\n");
            fwrite(STDERR, "Record it first: vendor/bin/cassette record $name\n");
            exit(1);
        }

        $refresh        = in_array('--refresh', $argv, true);
        $httpOnly       = in_array('--http-only', $argv, true);
        $screenshotOnly = in_array('--screenshot-only', $argv, true);
        $debugMode      = in_array('--debug', $argv, true);

        if ($httpOnly && $screenshotOnly) {
            fwrite(STDERR, "--http-only and --screenshot-only are mutually exclusive.\n");
            exit(1);
        }

        // Optional --base-url=https://... override so runs recorded on one host
        // can be replayed on a different host (CI, local, staging, ...).
        $baseUrl = null;
        foreach ($argv as $arg) {
            if (str_starts_with($arg, '--base-url=')) {
                $baseUrl = rtrim(substr($arg, strlen('--base-url=')), '/');
                break;
            }
        }

        // Open a log file for the complete replay output so past runs can be inspected.
        $replayLogPath = $cassettesDir . '/' . $name . '/replay.log';
        $replayLogFh   = fopen($replayLogPath, 'a');
        fwrite($replayLogFh, date('[Y-m-d H:i:s] ') . implode(' ', array_slice($argv, 1)) . "\n\n");

        // --- Step 1: HTTP body diff ---
        $config['mode'] = 'mock';
        $config['name'] = $name;

        file_put_contents($configPath, json_encode($config, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");

        // Clear stale diff files from previous runs before replaying.
        $httpDiffDir = $cassettesDir . '/' . $name . '/http';
        foreach (glob($httpDiffDir . '/*.diff') ?: [] as $diff) {
            unlink($diff);
        }

        $httpExitCode = 0;

        if (!$screenshotOnly) {
            replayEcho($replayLogFh, "\033[1m── HTTP replay ─────────────────────────────────────────\033[0m\n");
            $replayScript = __DIR__ . '/src/CassetteReplay.php';
            $replayArgs   = escapeshellarg($name) . ($baseUrl !== null ? ' ' . escapeshellarg($baseUrl) : '');
            passthruLogged('CASSETTE_ROOT=' . escapeshellarg($projectRoot) . " php $replayScript $replayArgs", $httpExitCode, $replayLogFh);

            if ($httpExitCode !== 0) {
                $remaining   = interactiveAcceptDiffs(
                    $cassettesDir . '/' . $name . '/http',
                    $cassettesDir . '/' . $name . '/http.json'
                );
                $httpExitCode = $remaining > 0 ? 1 : 0;
            }
        }

        // --- Step 2: Visual (Playwright) regression ---
        $screenshotExitCode = 0;

        if ($httpOnly) {
            $allPassed = ($httpExitCode === 0);
            clearState($configPath);
            replayEcho($replayLogFh, "\n" . str_repeat('─', 56) . "\n");
            if ($allPassed) {
                replayEcho($replayLogFh, "\033[32m✅ All checks passed\033[0m\n");
            } else {
                replayEcho($replayLogFh, "\033[31m⛔ Checks failed [HTTP diff]\033[0m\n");
                replayEcho($replayLogFh, "  Diff files: .cassette/runs/$name/http/*.diff\n");
            }
            fclose($replayLogFh);
            exit($allPassed ? 0 : 1);
        }

        replayEcho($replayLogFh, "\n\033[1m── Screenshot replay ───────────────────────────────────\033[0m\n");

        // Auto-install Node.js dependencies on first use.
        if (!is_dir(__DIR__ . '/node_modules')) {
            replayEcho($replayLogFh, "  Installing Node.js dependencies...\n");
            passthruLogged('cd ' . escapeshellarg(__DIR__) . ' && npm install --silent', $npmExit, $replayLogFh);

            if ($npmExit !== 0) {
                fwrite(STDERR, "\033[31m⛔ npm install failed. Cannot run Playwright tests.\033[0m\n");
                fclose($replayLogFh);
                exit(1);
            }
        }

        // Auto-install Playwright browser binary on first use.
        $chromiumMarker = __DIR__ . '/node_modules/.playwright-browsers-installed';

        if (!file_exists($chromiumMarker)) {
            replayEcho($replayLogFh, "  Installing Playwright browser...\n");
            passthruLogged('cd ' . escapeshellarg(__DIR__) . ' && npx playwright install chromium', $pwExit, $replayLogFh);

            if ($pwExit !== 0) {
                fwrite(STDERR, "\033[31m⛔ Playwright browser install failed.\033[0m\n");
                fclose($replayLogFh);
                exit(1);
            }

            file_put_contents($chromiumMarker, '1');
        }

        // mock mode is already active; cassette.spec.js resets the pointer
        // to 0 in test.beforeAll() so the screenshot run starts from request bucket 0.

        $snapshotDir = $cassettesDir . '/' . $name . '/screenshots';

        // --refresh: wipe existing baselines so they are recreated from scratch.
        if ($refresh && is_dir($snapshotDir)) {
            foreach (glob($snapshotDir . '/*.png') ?: [] as $png) {
                unlink($png);
            }
        }

        // First run (no baseline yet) or --refresh → create snapshots.
        // Subsequent runs → compare against existing baselines.
        $hasBaselines = is_dir($snapshotDir) && !empty(glob($snapshotDir . '/*.png'));
        $updateFlag   = $hasBaselines ? '' : ' --update-snapshots';

        $configFile = escapeshellarg(__DIR__ . '/src/playwright.config.js');
        $env        = 'CASSETTE_ROOT=' . escapeshellarg($projectRoot) . ' CASSETTE_NAME=' . escapeshellarg($name);
        if ($baseUrl !== null) {
            $env .= ' CASSETTE_BASE_URL=' . escapeshellarg($baseUrl);
        }
        if ($debugMode) {
            $env .= ' CASSETTE_DEBUG=1';
        }

        passthruLogged(
            'cd ' . escapeshellarg(__DIR__) . " && $env npx playwright test --config=$configFile$updateFlag",
            $screenshotExitCode,
            $replayLogFh
        );

        $allPassed = ($httpExitCode === 0 && $screenshotExitCode === 0);
        clearState($configPath);
        replayEcho($replayLogFh, "\n" . str_repeat('─', 56) . "\n");

        if ($allPassed) {
            replayEcho($replayLogFh, "\033[32m✅ All checks passed\033[0m\n");
        } else {
            replayEcho($replayLogFh, "\033[31m⛔ Checks failed\033[0m");
            if ($httpExitCode !== 0)        { replayEcho($replayLogFh, " [HTTP diff]"); }
            if ($screenshotExitCode !== 0)  { replayEcho($replayLogFh, " [Screenshots]"); }
            replayEcho($replayLogFh, "\n");
            if ($httpExitCode !== 0) {
                replayEcho($replayLogFh, "  Diff files: .cassette/runs/$name/http/*.diff\n");
            }
        }

        fclose($replayLogFh);

        exit($allPassed ? 0 : 1);

    case 'accept':
        $httpDiffDir = $cassettesDir . '/' . $name . '/http';
        $diffFiles   = glob($httpDiffDir . '/*.diff') ?: [];

        if (empty($diffFiles)) {
            echo "\033[32m✅ No open diffs for:\033[0m $name\n";
            break;
        }

        $remaining = interactiveAcceptDiffs(
            $httpDiffDir,
            $cassettesDir . '/' . $name . '/http.json'
        );
        exit($remaining > 0 ? 1 : 0);

    case 'delete':
        $deleteAll = in_array('--all', $argv, true);
        $force     = in_array('--force', $argv, true);

        if ($deleteAll) {
            $runs = array_filter(
                scandir($cassettesDir) ?: [],
                static fn(string $entry): bool =>
                    $entry !== '.' && $entry !== '..' &&
                    is_dir($cassettesDir . '/' . $entry) &&
                    file_exists($cassettesDir . '/' . $entry . '/http.json')
            );

            if (empty($runs)) {
                echo "No runs to delete.\n";
                break;
            }

            if (!$force) {
                echo "Delete \033[33m" . count($runs) . " run(s)\033[0m and all their data? [y/n] ";
                $answer = strtolower(trim((string) fgets(STDIN)));

                if ($answer !== 'y') {
                    echo "Aborted.\n";
                    exit(1);
                }
            }

            foreach ($runs as $run) {
                deleteDir($cassettesDir . '/' . $run);
            }

            clearState($configPath);

            echo "\033[32m✅ Deleted " . count($runs) . " run(s).\033[0m\n";
            break;
        }

        $runDir = $cassettesDir . '/' . $name;

        if ($name === '' || !is_dir($runDir)) {
            fwrite(STDERR, "Run not found: $name\n");
            exit(1);
        }

        if (!$force) {
            echo "Delete run \033[33m$name\033[0m and all its data? [y/n] ";
            $answer = strtolower(trim((string) fgets(STDIN)));

            if ($answer !== 'y') {
                echo "Aborted.\n";
                exit(1);
            }
        }

        deleteDir($runDir);

        // Clear config if it referenced this run.
        if (($config['name'] ?? '') === $name) {
            clearState($configPath);
        }

        echo "\033[32m✅ Deleted run:\033[0m $name\n";
        break;

    case 'list':
        $runs = array_filter(
            scandir($cassettesDir) ?: [],
            static fn(string $entry): bool =>
                $entry !== '.' && $entry !== '..' &&
                is_dir($cassettesDir . '/' . $entry) &&
                file_exists($cassettesDir . '/' . $entry . '/http.json')
        );

        if (empty($runs)) {
            echo "  No runs recorded yet.\n";
            break;
        }

        $active = (($config['mode'] ?? '') !== '') ? ($config['name'] ?? '') : '';

        foreach (array_values($runs) as $run) {
            $screenshots = glob($cassettesDir . '/' . $run . '/screenshots/*.png') ?: [];
            $httpLog     = $cassettesDir . '/' . $run . '/http.json';
            $requests    = 0;

            if (file_exists($httpLog)) {
                $raw          = (string) file_get_contents($httpLog);
                // Support gzip-compressed files as well as legacy plain-text files.
                $decompressed = @gzdecode($raw);
                $requests     = count(json_decode($decompressed !== false ? $decompressed : $raw, true) ?? []);
            }

            $marker         = $run === $active ? " \033[33m← active\033[0m" : '';
            $screenshotInfo = count($screenshots) > 0 ? '  ' . count($screenshots) . ' screenshot(s)' : '';
            $icon           = $run === $active ? '●' : '○';

            echo sprintf("  \033[36m%s\033[0m %-28s %d request(s)%s%s\n", $icon, $run, $requests, $screenshotInfo, $marker);
        }
        break;

    default:
        fwrite(STDERR, "\033[31m⛔ Unknown command: $command\033[0m\n");
        fwrite(STDERR, "Valid commands: up, down, record, replay, accept, stop, delete, list\n");
        exit(1);
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

/**
 * Write to both stdout and the replay log file simultaneously.
 *
 * @param resource $logFh
 */
function replayEcho($logFh, string $text): void
{
    echo $text;
    fwrite($logFh, $text);
}

/**
 * Run a shell command, stream its stdout to both the terminal and the log file
 * in real time, and capture its exit code.
 *
 * Uses proc_open + stream_select to avoid blocking on either stdout or stderr.
 *
 * @param resource $logFh
 */
function passthruLogged(string $cmd, int &$exitCode, $logFh): void
{
    $proc = proc_open($cmd, [1 => ['pipe', 'w'], 2 => ['pipe', 'w']], $pipes);
    if ($proc === false) {
        $exitCode = 1;
        return;
    }

    stream_set_blocking($pipes[1], false);
    stream_set_blocking($pipes[2], false);

    while (true) {
        $read = array_filter([$pipes[1], $pipes[2]], static fn($p): bool => is_resource($p) && !feof($p));
        if (empty($read)) {
            break;
        }
        $write   = null;
        $except  = null;
        if (stream_select($read, $write, $except, 1) === false) {
            break;
        }
        foreach ($read as $stream) {
            $chunk = fread($stream, 8192);
            if ($chunk === false || $chunk === '') {
                continue;
            }
            if ($stream === $pipes[1]) {
                // stdout: show on terminal and write to log.
                echo $chunk;
                flush();
                fwrite($logFh, $chunk);
            } else {
                // stderr: show on terminal only (avoids polluting the log with
                // Playwright's internal noise, but still visible to the user).
                fwrite(STDERR, $chunk);
            }
        }
    }

    foreach ($pipes as $pipe) {
        if (is_resource($pipe)) {
            fclose($pipe);
        }
    }

    $exitCode = proc_close($proc);
}

/**
 * Delete the state file — absence of state.json means 'stopped'.
 */
function clearState(string $configPath): void
{
    if (file_exists($configPath)) {
        unlink($configPath);
    }
}

/**
 * Show each .diff file interactively and let the user accept or skip.
 * On accept the corresponding http.json entry is updated in-place and
 * the .diff / .actual files are removed.
 *
 * @return int Number of diffs that were NOT accepted (i.e. still failing).
 */
function interactiveAcceptDiffs(string $httpDiffDir, string $httpLogPath): int
{
    $diffFiles = glob($httpDiffDir . '/*.diff') ?: [];

    if (empty($diffFiles)) {
        return 0;
    }

    if (!file_exists($httpLogPath)) {
        fwrite(STDERR, "http.json not found: $httpLogPath\n");
        return count($diffFiles);
    }

    // Support gzip-compressed http.json (written by CassetteHttpRecorder) as well
    // as legacy plain-text files recorded before compression was added.
    $rawLog       = (string) file_get_contents($httpLogPath);
    $decompressed = @gzdecode($rawLog);
    $httpLog      = json_decode($decompressed !== false ? $decompressed : $rawLog, true) ?? [];
    $wasGzipped   = $decompressed !== false;
    $accepted     = 0;
    $skipped      = 0;

    foreach ($diffFiles as $diffFile) {
        $step       = (int) basename($diffFile, '.diff');
        $entryIndex = $step - 1;
        $actualFile = substr($diffFile, 0, -5) . '.actual';

        echo "\n" . str_repeat('─', 56) . "\n";
        echo file_get_contents($diffFile);
        echo str_repeat('─', 56) . "\n";

        if (!file_exists($actualFile)) {
            echo "\033[33m⚠ No .actual file found — re-run replay first.\033[0m\n";
            $skipped++;
            continue;
        }

        if (!isset($httpLog[$entryIndex])) {
            echo "\033[33m⚠ Entry #$step not found in http.json.\033[0m\n";
            $skipped++;
            continue;
        }

        echo "[a] accept  [s] skip  > ";
        fflush(STDOUT);
        $answer = strtolower(trim((string) fgets(STDIN)));

        if ($answer !== 'a') {
            echo "  Skipped.\n";
            $skipped++;
            continue;
        }

        $httpLog[$entryIndex]['response']['body'] = (string) file_get_contents($actualFile);
        unlink($diffFile);
        unlink($actualFile);
        echo "  \033[32mAccepted.\033[0m\n";
        $accepted++;
    }

    if ($accepted > 0) {
        $encoded = (string) json_encode($httpLog, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE);
        file_put_contents(
            $httpLogPath,
            // Preserve the on-disk encoding: re-gzip when the source was gzipped,
            // otherwise write pretty-printed JSON as the legacy format did.
            $wasGzipped
                ? gzencode($encoded, 6)
                : (string) json_encode($httpLog, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n"
        );
    }

    echo "\n" . str_repeat('─', 56) . "\n";
    echo "\033[32m$accepted accepted\033[0m, $skipped skipped.\n";

    return $skipped;
}

/**
 * Recursively delete all files and subdirectories inside a directory,
 * then remove the directory itself.
 */
function deleteDir(string $dir): void
{
    if (!is_dir($dir)) {
        return;
    }

    foreach (scandir($dir) as $entry) {
        if ($entry === '.' || $entry === '..') {
            continue;
        }

        $path = $dir . '/' . $entry;

        if (is_dir($path)) {
            deleteDir($path);
        } else {
            unlink($path);
        }
    }

    rmdir($dir);
}
